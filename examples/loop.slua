--!!type:strict
import io

function main():int2
    local sum:int64 = 0
    local a:int64 = 0

    for i = 0, i < 100, i + 1 do
        if i == 5 then
            break
        end
        print(i)
    end

    while a < 10 do
        print("while :"..a)
        a = a + 1
    end
    for i = 0, i < 10, i + 1 do
        sum = sum + i
        print("num :".. i)
    end
    print("total sum is "..sum)
    print("end")
    return 0
end